# NAS Music Player - 环境变量配置
# 复制此文件为 .env 并修改

# 音乐目录（NAS上的路径）
MUSIC_DIR=/share/Public/music

# 数据目录（数据库等持久化数据）
DATA_DIR=./data

# 配置目录（users.json等配置文件）
CONFIG_DIR=./config

# JWT密钥（必须修改！使用命令生成：python -c "import secrets; print(secrets.token_hex(32))"）
SECRET_KEY=f5a3b9c0d1e2f4a5b6c7d8e9f0a1b2c3d4e5f6a7b8c9d0e1f2a3b4c5d6e7f8a9

# CORS允许的来源（逗号分隔，留空则只允许同源请求）
# 例如：CORS_ORIGINS=https://your-domain.com,http://localhost:8080
CORS_ORIGINS=

# 端口映射
PORT=3003
