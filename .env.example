# NAS Music Player - 环境变量配置
# 复制此文件为 .env 并修改

# 音乐目录（NAS上的路径）
MUSIC_DIR=/mnt/music

# 数据目录（数据库等持久化数据）
DATA_DIR=./data

# 配置目录（users.json等配置文件）
CONFIG_DIR=./config

# JWT密钥（必须修改！使用命令生成：python -c "import secrets; print(secrets.token_hex(32))"）
SECRET_KEY=change-me-in-production

# CORS允许的来源（逗号分隔，留空则只允许同源请求）
# 例如：CORS_ORIGINS=https://your-domain.com,http://localhost:8080
CORS_ORIGINS=

# 端口映射
PORT=8080
